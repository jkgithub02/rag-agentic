# AWS / Bedrock
AGENTIC_RAG_AWS_REGION=ap-southeast-5
AGENTIC_RAG_BEDROCK_CHAT_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
AGENTIC_RAG_REASONING_ENABLED=true
AGENTIC_RAG_REASONING_TEMPERATURE=0.0
AGENTIC_RAG_REASONING_MAX_TOKENS=300
AGENTIC_RAG_STREAM_TOKEN_DELAY_SECONDS=0.015
AGENTIC_RAG_EMBEDDING_PROVIDER=ollama
AGENTIC_RAG_OLLAMA_BASE_URL=http://localhost:11434
AGENTIC_RAG_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Vector DB
AGENTIC_RAG_VECTOR_COLLECTION_NAME=paper_chunks

# Retrieval / validation
AGENTIC_RAG_RETRIEVAL_TOP_K=4
AGENTIC_RAG_RETRIEVAL_NEIGHBOR_SPAN=1
AGENTIC_RAG_RETRIEVAL_MODE=hybrid
AGENTIC_RAG_RETRIEVAL_DENSE_WEIGHT=0.65
AGENTIC_RAG_RETRIEVAL_SPARSE_WEIGHT=0.35
AGENTIC_RAG_CONTEXT_COMPRESSION_BASE_THRESHOLD=2000
AGENTIC_RAG_CONTEXT_COMPRESSION_GROWTH_FACTOR=0.9
AGENTIC_RAG_AGENT_MAX_ITERATIONS=10
AGENTIC_RAG_AGENT_MAX_TOOL_CALLS=8
AGENTIC_RAG_MIN_RELEVANCE_SCORE=0.12
AGENTIC_RAG_AMBIGUITY_MARGIN=0.005

# Uploads
AGENTIC_RAG_UPLOAD_MAX_FILE_SIZE_MB=25

